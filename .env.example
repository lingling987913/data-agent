# Data Agent environment variables
API_TOKEN=dev-token-change-me

# API 暴露范围（公网部署务必改为 competition 或 demo，并更换 API_TOKEN）
#   full         — 全部端点（本地开发默认）
#   competition  — 仅 GET /health + competition-task 三端点
#   demo         — competition + structuring/modes、parsing/parse、super-agent/capabilities
# API_EXPOSE_SCOPE=full
# 内网/前端旁路：私网 IP，或请求头 X-Internal-Request / X-Internal-Token = INTERNAL_API_TOKEN
# INTERNAL_API_TOKEN=

# ══════════════════════════════════════════════════════════════════════════════
# 文档解析路由（由代码决定，此处仅说明，无需额外开关）
#   · docx / xlsx / ppt / txt / md  → 本地解析（默认不走 MinerU）
#   · pdf / 扫描件图片              → 本地 MinerU（默认优先）→ MinerU 官方 mineru.net → pdftotext
#   · docx 嵌入图 + PARSING_ENABLE_IMAGE_DESC → 本地抽图 + VLM（不触发 MinerU 在线 API）
#   · Office 全文 MinerU              → 仅 parser_type=mineru_agent（前端/API 显式选择）
# ══════════════════════════════════════════════════════════════════════════════

# ── 1) LLM — 默认文本模型（Review / Super-Agent / 编排 / 结构化等）──────────
# Provider：阿里云百炼 DashScope OpenAI 兼容端点（模型 id 如 qwen3.6-27b）
#   国内：https://dashscope.aliyuncs.com/compatible-mode/v1
#   国际：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 备选 SiliconFlow：https://api.siliconflow.cn/v1（模型 id 需改为 Qwen/Qwen3.6-27B）
# 旧版 OPENAI_* 仍可用作回退
LLM_API_KEY=your-dashscope-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen3.6-27b
# Qwen 建议关闭思考链，便于 Agno output_schema 稳定输出 JSON：
LLM_EXTRA_BODY="{\"chat_template_kwargs\":{\"enable_thinking\":false}}"
# GLM 端点可用：LLM_EXTRA_BODY={"thinking":{"type":"disabled"}}

# ── 2) VLM — 视觉/多模态（嵌入图、图块描述；不回退文本模型）────────────────
# 旧版 PARSING_VISION_LLM_* 仍可用作回退
# 与 LLM 同 Provider（DashScope compatible-mode）；须为原生 VL / multimodal 模型。
# 纯文本模型无法解析 image_url；若改用 MiniMax-M2.x，请配 MINIMAX_CN_API_KEY 并安装 mmx CLI。
VLM_API_KEY=your-dashscope-api-key
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL_NAME=qwen3.6-27b
VLM_EXTRA_BODY="{\"chat_template_kwargs\":{\"enable_thinking\":false}}"
# MINIMAX_CN_API_KEY=your-minimax-cn-api-key

# ── 3) LIGHT_LLM — 可选轻量文本模型（解析/公式优先；未配置则回退 LLM_*）────
# 回退链：LIGHT_LLM → LIGHTWEIGHT（已弃用别名）→ LLM → 旧版 PARSING_LLM / OPENAI
# 可选：与主模型（DashScope qwen3.6-27b）分离的轻量端点，解析/公式场景优先
# Provider：SiliconFlow https://api.siliconflow.cn/v1（Qwen/Qwen3.5-4B，与 RERANKER 共用 Key）
# LIGHT_LLM_API_KEY=your-siliconflow-api-key
# LIGHT_LLM_BASE_URL=https://api.siliconflow.cn/v1
# LIGHT_LLM_MODEL_NAME=Qwen/Qwen3.5-4B
# LIGHT_LLM_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":false}}

# ── 4) LIGHT_VLM — 可选轻量视觉模型（OPTIMAL 模式优先；未配置则回退 VLM_*）─
# 回退链：LIGHT_VLM → VLM → 旧版 PARSING_VISION_LLM_*
# 可选：与主 VLM（DashScope qwen3.6-27b）分离的轻量 VL 端点
# 必须使用真正的 VL 模型，例如 Qwen/Qwen2.5-VL-7B-Instruct 或 Qwen/Qwen3-VL-4B-Instruct；
# 不要填 Qwen/Qwen3.5-4B 这类纯文本模型，否则会被跳过。
# LIGHT_VLM_API_KEY=your-siliconflow-api-key
# LIGHT_VLM_BASE_URL=https://api.siliconflow.cn/v1
# LIGHT_VLM_MODEL_NAME=Qwen/Qwen3-VL-8B-Instruct
# LIGHT_VLM_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":false}}

# COMPLIANCE_AGENTS_ENABLED=1

# ── 日志 ────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# AGNO_LOG_ENABLED=1
# AGNO_LOG_PATH=.dev/logs/agno.log
# AGNO_LOG_LEVEL=DEBUG          # Agno agent/team/workflow 详细日志（默认 DEBUG）
# AGNO_DEBUG_LEVEL=2            # 1=基础  2=更详细（prompt/response 等）
# AGNO_LOG_TRACEBACKS=0
# AGENT_DEBUG_CONSOLE=1         # 调试埋点同时输出到控制台
# AGENT_DEBUG_LOG_PATH=.dev/logs/agent-debug.log

# ── MinerU 官方在线 API（mineru.net）────────────────────────────────────────
# 两套 API（详见 https://mineru.net/apiManage/docs）：
#   · Agent 轻量 API（/api/v1/agent）— 免 Token，≤10MB/20页，仅 Markdown
#   · v4 精准解析 API（/api/v4）— 需 Token，≤200MB/200页，Zip 含 Markdown/JSON/表格/公式
# 默认策略：小文件走 Agent；大文件/legacy .doc/.ppt/.xls 或 Agent 超限自动切 v4（需 Token）
# MINERU_AGENT_API_TOKEN=          # v4 必填；Agent 可选（配置了才启用大文件/legacy 格式）

# Agent 轻量 API：只作为兜底，不作为正式链路
MINERU_AGENT_API_BASE=https://mineru.net/api/v1/agent

# v4 精准 API：正式链路
MINERU_EXTRACT_API_BASE=https://mineru.net/api/v4

# 推荐：正式工程默认走 extract，不建议 auto 作为生产默认
MINERU_API_MODE=extract

# Agent 轻量 API 可禁用，避免误走轻量链路
MINERU_AGENT_API_ENABLED=0

# v4 精准 API 必须启用
MINERU_EXTRACT_API_ENABLED=1

# 非 HTML 文档默认用 vlm；HTML 文件由代码层自动切 MinerU-HTML
MINERU_EXTRACT_MODEL_VERSION=vlm

# 中文/中英文航天文档
MINERU_AGENT_LANGUAGE=ch

# 正式解析建议不要全局强制 page_ranges，避免只解析前 20 页
# MINERU_EXTRACT_PAGE_RANGES=
# MINERU_AGENT_PAGE_RANGE=

# OCR 不建议固定死。最好由程序根据 PDF 类型动态判断。
# 扫描件 true，原生电子 PDF false。
MINERU_AGENT_IS_OCR=false

# 表格和公式建议开启
MINERU_AGENT_ENABLE_TABLE=true
MINERU_AGENT_ENABLE_FORMULA=true
MINERU_AGENT_PARSE_MODE=hybrid-auto-engine

# 综合审查前端使用的 MinerU 调用配置
# 实际生效位置：web/.env.local 中的 NEXT_PUBLIC_COMPREHENSIVE_REVIEW_MINERU_*
NEXT_PUBLIC_COMPREHENSIVE_REVIEW_MINERU_PARSER=mineru
# 本地 MinerU parse_method 仅支持 auto / ocr / txt
NEXT_PUBLIC_COMPREHENSIVE_REVIEW_MINERU_PARSE_MODE=auto

# 轮询超时
MINERU_AGENT_POLL_TIMEOUT_SECONDS=300
MINERU_EXTRACT_POLL_TIMEOUT_SECONDS=1200

# ── MinerU 本地 HTTP（POST /file_parse）────────────────────────────────────
# MINERU_LOCAL_FIRST=1 时解析顺序：本地 → 在线 mineru.net → pdftotext
# 仅走本地、不调在线 API 时可设 MINERU_API_MODE=local_only
MINERU_LOCAL_ENABLED=1
MINERU_LOCAL_FIRST=1
MINERU_LOCAL_API_BASE=http://localhost:8000
MINERU_LOCAL_PARSE_METHOD=auto
MINERU_LOCAL_BACKEND=hybrid-auto-engine
# MINERU_LOCAL_LANG_LIST=ch
# MINERU_LOCAL_TABLE_ENABLE=true
# MINERU_LOCAL_FORMULA_ENABLE=true
# MINERU_LOCAL_CONNECT_TIMEOUT_SECONDS=10
# MINERU_LOCAL_REQUEST_TIMEOUT_SECONDS=300

# ── 可选：Review-Plus / 解析切片 ────────────────────────────────────────────
# VLM 解析合理性校准单次请求超时（秒）；未设时回退 STRUCTURING_LLM_TIMEOUT（默认 300）
# PARSING_CALIBRATION_LLM_TIMEOUT=300
# STRUCTURING_LLM_TIMEOUT=300
# PARSING_CALIBRATION_MAX_BLOCKS=50
# PARSING_CALIBRATION_MAX_CONCURRENCY=6
# parse-preview 与正式解析：对 figure 块裁剪原图并用 VLM_* 生成描述
# 对 Word：仅触发本地 docx 抽图 + VLM，不会因此调用 MinerU 在线 API
# Office 全文 MinerU 解析需在前端/API 显式选择 parser_type=mineru_agent
# PARSING_ENABLE_IMAGE_DESC=1
# PARSING_IMAGE_DESC_MAX_CONCURRENCY=4
# REVIEW_PLUS_AGENTS_ENABLED=1
# REVIEW_PLUS_LLM_MODEL_ID=
# CHUNKING_MAX_CONCURRENCY=3
# CHUNKING_WINDOW_SIZE=5
# CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ── SMART × Hermes 编排（默认关闭，按需启用）────────────────────────────────
# Adaptive Router：classify_and_route 阶段 LLM 辅助路由 + Guardrail
# ADAPTIVE_ROUTER_ENABLED=0
# Generic LLM Harness：generic 域 specialist 走真实 LLM（非 deterministic 回退）
# SMART_GENERIC_LLM_ENABLED=0
# TaskBoard 文件快照：storage/runs/task_boards/{run_id}.json（resume 辅助恢复）
# TASK_BOARD_FILE_STORE_ENABLED=0

# ── 可选：RAGFlow 上传（GNC 审查材料同步）──────────────────────────────────
# RAGFLOW_API_URL=http://your-ragflow-host/
# RAGFLOW_API_KEY=ragflow-your-api-key
# RAGFLOW_GNC_REVIEW_DATASET_ID=

# ── 以下变量来自 aq-aero 迁移，data-agent 当前代码未读取，可保留或删除 ─────
# QUERY_REWRITER_API_KEY=
# QUERY_REWRITER_API_URL=https://openrouter.ai/api/v1
# QUERY_REWRITER_MODEL=stepfun/step-3.5-flash:free
# RERANKER_PROVIDER=bge
# RERANKER_API_URL=https://api.siliconflow.cn/v1/rerank
# RERANKER_API_KEY=
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
