{
  "template_id": "GNC_ALL",
  "name": "GNC 设计评审（CDR，AD+AC 联合）",
  "subsystem": "GNC",
  "review_phase": "CDR",
  "review_scope": "ad_ac",
  "template_version": "2026.1",
  "description": "姿态确定与姿态控制联合 CDR 审查规则基线，覆盖 AD 5 个环节与 AC 8 个环节。",
  "required_materials": [
    {
      "name": "GNC 设计报告（姿态确定分册）",
      "description": "含需求分解、误差预算、算法设计、仿真与试验结论",
      "required": true
    },
    {
      "name": "姿态确定需求与指标分解表",
      "description": "上级需求到 AD 指标的追溯与量化定义",
      "required": true
    },
    {
      "name": "姿态确定数学仿真报告",
      "description": "覆盖稳态/机动等典型工况的仿真结果与统计分析",
      "required": true
    },
    {
      "name": "单机安装与标定说明",
      "description": "星敏/陀螺等测量单机安装矩阵与标定残差",
      "required": false
    },
    {
      "name": "GNC 设计报告（姿态控制分册）",
      "description": "含控制指标、执行机构布局、控制律与仿真结论",
      "required": true
    },
    {
      "name": "姿态控制需求与指标分解表",
      "description": "上级需求到 AC 指标的追溯与量化定义",
      "required": true
    },
    {
      "name": "执行机构布局与能力说明",
      "description": "推力器/飞轮/磁力矩器等布局与能力边界",
      "required": true
    },
    {
      "name": "控制律与参数设计说明",
      "description": "控制架构、参数整定、操纵律与卸载律",
      "required": true
    },
    {
      "name": "姿态控制闭环仿真报告",
      "description": "覆盖典型机动与稳态工况的闭环仿真结果",
      "required": true
    },
    {
      "name": "姿控地面试验或半实物仿真报告",
      "description": "关键控制性能验证数据",
      "required": false
    }
  ],
  "required_sections": [
    {
      "section": "1 姿态确定需求确认与误差分解",
      "description": "技术指标量化定义、误差预算与分解链路",
      "required": true,
      "subsections": [
        {
          "title": "1.1 姿态确定技术要求"
        },
        {
          "title": "1.2 误差分解与预算"
        }
      ]
    },
    {
      "section": "2 采集时序设计",
      "description": "测量采样周期、同步策略与时序裕度",
      "required": true,
      "subsections": [
        {
          "title": "2.1 采样周期与同步"
        },
        {
          "title": "2.2 时序裕度分析"
        }
      ]
    },
    {
      "section": "3 姿态测量单机安装指向设计",
      "description": "安装矩阵、视场约束与标定残差",
      "required": true,
      "subsections": [
        {
          "title": "3.1 安装矩阵与指向"
        },
        {
          "title": "3.2 标定残差与可用性"
        }
      ]
    },
    {
      "section": "4 姿态确定算法设计",
      "description": "滤波融合、观测方程与鲁棒性设计",
      "required": true,
      "subsections": [
        {
          "title": "4.1 算法架构与观测方程"
        },
        {
          "title": "4.2 滤波融合与鲁棒性"
        }
      ]
    },
    {
      "section": "5 姿态确定数学仿真与结果分析",
      "description": "仿真工况、结果统计与需求符合性",
      "required": true,
      "subsections": [
        {
          "title": "5.1 稳态仿真结果"
        },
        {
          "title": "5.2 机动/瞬态仿真结果"
        }
      ]
    },
    {
      "section": "6 姿态控制需求确认与误差分解",
      "description": "控制指标量化、执行机构能力匹配与误差预算",
      "required": true,
      "subsections": [
        {
          "title": "6.1 姿态控制技术要求"
        },
        {
          "title": "6.2 执行机构能力与指标分解"
        }
      ]
    },
    {
      "section": "7 推力器布局设计",
      "description": "推力器布置、喷口指向与冗余策略",
      "required": true,
      "subsections": [
        {
          "title": "7.1 推力器布置方案"
        },
        {
          "title": "7.2 推力偏差与冗余分析"
        }
      ]
    },
    {
      "section": "8 其他执行机构布局设计",
      "description": "飞轮、磁力矩器等布局与角动量管理约束",
      "required": true,
      "subsections": [
        {
          "title": "8.1 飞轮布局与容量"
        },
        {
          "title": "8.2 磁力矩器与其他执行机构"
        }
      ]
    },
    {
      "section": "9 控制律设计",
      "description": "控制架构、稳定性与鲁棒性设计",
      "required": true,
      "subsections": [
        {
          "title": "9.1 控制架构与模式切换"
        },
        {
          "title": "9.2 稳定性与鲁棒性分析"
        }
      ]
    },
    {
      "section": "10 控制参数设计",
      "description": "参数整定、裕度与限幅设计",
      "required": true,
      "subsections": [
        {
          "title": "10.1 参数整定方法"
        },
        {
          "title": "10.2 裕度与限幅"
        }
      ]
    },
    {
      "section": "11 操纵律设计",
      "description": "姿态机动路径规划与机动律",
      "required": true,
      "subsections": [
        {
          "title": "11.1 机动路径与约束"
        },
        {
          "title": "11.2 大角度机动性能"
        }
      ]
    },
    {
      "section": "12 卸载律设计",
      "description": "角动量卸载策略与饱和保护",
      "required": true,
      "subsections": [
        {
          "title": "12.1 卸载触发与方式"
        },
        {
          "title": "12.2 饱和保护与扰动影响"
        }
      ]
    },
    {
      "section": "13 姿态控制仿真与结果分析",
      "description": "闭环仿真工况、统计结论与指标符合性",
      "required": true,
      "subsections": [
        {
          "title": "13.1 稳态控制仿真"
        },
        {
          "title": "13.2 机动与极限工况仿真"
        }
      ]
    }
  ],
  "quality_checklist": [
    "送审材料章节齐全，版本与封面一致",
    "关键指标均已量化并注明单位与统计口径（如 3σ）",
    "误差分解链路闭合，无未分配误差项",
    "仿真工况覆盖需求规定的典型工作模式",
    "图表编号、指标数值与正文交叉引用一致",
    "控制指标均已量化并注明单位与统计口径",
    "执行机构能力与控制指标匹配关系明确",
    "控制律、参数、操纵律与卸载律设计链路闭合",
    "仿真工况覆盖需求规定的典型机动与稳态模式",
    "推力器冗余与故障模式下的控制能力有说明"
  ],
  "discipline_review_points": {
    "ad": {
      "discipline_name": "姿态确定",
      "checklist": [
        "送审材料章节齐全，版本与封面一致",
